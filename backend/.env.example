# Environment
NODE_ENV=development
PORT=3000

# MongoDB (User Database - Atlas Free)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# PostgreSQL (Products, Orders, History)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=feriwala_db
PG_USER=feriwala
PG_PASSWORD=<your_pg_password>

# JWT — use long random strings, e.g.: openssl rand -hex 64
JWT_SECRET=<your_jwt_secret>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<your_jwt_refresh_secret>
JWT_REFRESH_EXPIRES_IN=30d

# Google Maps API
GOOGLE_MAPS_API_KEY=<your_google_maps_api_key>

# Server URL
SERVER_URL=http://localhost:3000

# AWS S3 (Media uploads)
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
AWS_REGION=ap-south-1
AWS_S3_BUCKET=feriwala-media

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Socket.IO — comma-separated allowed origins
SOCKET_CORS_ORIGIN=http://localhost:3000

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# DB connection tuning (optional)
DB_RETRY_INTERVAL_MS=30000
HEALTHCHECK_TIMEOUT_MS=2000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=20000
PG_CONNECT_TIMEOUT_MS=5000
PG_POOL_ACQUIRE_TIMEOUT_MS=10000
